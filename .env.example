# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Notion
NOTION_API_KEY=your_notion_integration_token_here
NOTION_ITEMS_DB_ID=your_notion_items_database_id_here
NOTION_PROJECTS_DB_ID=your_notion_projects_database_id_here
NOTION_PEOPLE_DB_ID=your_notion_people_database_id_here
NOTION_DECISIONS_DB_ID=your_notion_decisions_database_id_here
NOTION_SOPS_DB_ID=your_notion_sops_database_id_here
NOTION_SCORECARD_DB_ID=your_notion_scorecard_database_id_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_key_here

# Postmark (inbound email)
POSTMARK_INBOUND_TOKEN=your_postmark_inbound_token_here

# Twilio (SMS bot)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# OpenPhone (webhook signature verification)
OPENPHONE_WEBHOOK_SECRET=your_openphone_webhook_secret_here

# GroupMe (webhook token)
GROUPME_BOT_ID=your_groupme_bot_id_here

# Slack (webhook verification)
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Whisper API (OpenAI, for voice memo transcription only)
OPENAI_API_KEY=your_openai_api_key_here

# App
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
